# ==============================================================================
# VENDORi Website - Environment Variables Template
# ==============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# ==============================================================================
# PUBLIC VARIABLES (Exposed to Browser)
# ==============================================================================
# Only use NEXT_PUBLIC_ prefix for variables that MUST be accessible in browser

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=VENDORi GmbH
NEXT_PUBLIC_CONTACT_EMAIL=info@vendori.de
NEXT_PUBLIC_CONTACT_PHONE=+49 XXX XXXXXXX

# ==============================================================================
# PRIVATE VARIABLES (Server-Only)
# ==============================================================================
# These are only accessible in server-side code and API routes
# NEVER use NEXT_PUBLIC_ prefix for sensitive data

# ==============================================================================
# EMAIL CONFIGURATION (Server-Only - REQUIRED for Contact Form)
# ==============================================================================
# SMTP Server Configuration
# Common providers:
# - 1&1 IONOS: smtp.ionos.de (Port 587 TLS or 465 SSL)
# - Strato: smtp.strato.de (Port 465 SSL)
# - Gmail: smtp.gmail.com (Port 587 TLS) - requires App Password
# - Office365: smtp.office365.com (Port 587 TLS)

SMTP_HOST=smtp.example.com        # Your SMTP server hostname
SMTP_PORT=587                      # 587 for TLS, 465 for SSL
SMTP_SECURE=false                  # true for port 465 (SSL), false for 587 (TLS)
SMTP_USER=your-email@example.com  # SMTP username (usually your email address)
SMTP_PASS=your-password-here      # SMTP password or app-specific password

# Email Settings
EMAIL_FROM=your-email@example.com # Sender address (must match SMTP_USER)
EMAIL_FROM_NAME=VENDORi GmbH      # Sender display name
EMAIL_TO=info@vendori.eu          # Recipient for contact form submissions

# Rate Limiting (Optional - defaults shown)
RATE_LIMIT_WINDOW=60000           # Time window in milliseconds (default: 1 minute)
RATE_LIMIT_MAX_REQUESTS=5         # Max requests per window per IP (default: 5)

# ==============================================================================
# DATABASE (Optional - for future use)
# ==============================================================================
# DATABASE_URL=
# API_SECRET_KEY=

# ==============================================================================
# SECURITY WARNINGS
# ==============================================================================
# ⚠️ CRITICAL: Never commit .env.local or .env to Git
# ⚠️ Use strong, unique values for all secrets (min 32 characters)
# ⚠️ Rotate secrets regularly (at least every 90 days)
# ⚠️ Use different values for development/staging/production
# ⚠️ Never expose API keys or secrets with NEXT_PUBLIC_ prefix
# ⚠️ Review all environment variables before deployment
