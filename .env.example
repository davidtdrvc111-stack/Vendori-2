# ==============================================================================
# VENDORi Website - Environment Variables Template
# ==============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# ==============================================================================
# PUBLIC VARIABLES (Exposed to Browser)
# ==============================================================================
# Only use NEXT_PUBLIC_ prefix for variables that MUST be accessible in browser

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=VENDORi GmbH

# Analytics & Tracking (Requires Cookie Consent)
# Only loaded after user accepts analytics cookies (DSGVO-compliant)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_PROJECT_ID=xxxxxxxxxx

# ==============================================================================
# PRIVATE VARIABLES (Server-Only)
# ==============================================================================
# These are only accessible in server-side code and API routes
# NEVER use NEXT_PUBLIC_ prefix for sensitive data

# ==============================================================================
# CSRF PROTECTION (Server-Only - REQUIRED)
# ==============================================================================
# Secret key for HMAC-SHA256 signing of CSRF tokens
# CRITICAL: This secret validates CSRF tokens to prevent cross-site request forgery
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be at least 64 characters (32 bytes in hex)
# NEVER commit this value - keep it secure in .env.local
CSRF_SECRET=your-64-character-hex-secret-here

# Optional: CSRF Token Expiry (default: 3600000ms = 1 hour)
# CSRF_TOKEN_EXPIRY=3600000

# ==============================================================================
# EMAIL CONFIGURATION (Server-Only - LEGACY)
# ==============================================================================
# NOTE: The contact form now uses n8n webhooks (see N8N section below).
# SMTP configuration is kept for backward compatibility or alternative use.
# SMTP Server Configuration
# Common providers:
# - 1&1 IONOS: smtp.ionos.de (Port 587 TLS or 465 SSL)
# - Strato: smtp.strato.de (Port 465 SSL)
# - Gmail: smtp.gmail.com (Port 587 TLS) - requires App Password
# - Office365: smtp.office365.com (Port 587 TLS)

SMTP_HOST=smtp.example.com        # Your SMTP server hostname
SMTP_PORT=587                      # 587 for TLS, 465 for SSL
SMTP_SECURE=false                  # true for port 465 (SSL), false for 587 (TLS)
SMTP_USER=your-email@example.com  # SMTP username (usually your email address)
SMTP_PASS=your-password-here      # SMTP password or app-specific password

# Email Settings
EMAIL_FROM=your-email@example.com # Sender address (must match SMTP_USER)
EMAIL_FROM_NAME=VENDORi GmbH      # Sender display name
EMAIL_TO=info@vendori.eu          # Recipient for contact form submissions

# ==============================================================================
# N8N WEBHOOK INTEGRATION (Server-Only - REQUIRED for Contact Form)
# ==============================================================================
# VENDORi uses n8n workflow automation for contact form processing.
# The workflow handles:
# - Email delivery to VENDORi team
# - Automated confirmation email to sender
# - CRM/database integration (if configured)
#
# SECURITY: Both values are MANDATORY for production deployment
# The contact form will fail without these variables.

# n8n Webhook URL
# Format: https://your-n8n-instance.com/webhook/your-webhook-id
# Example: https://n8n.vendori.eu/webhook/abc123-def456-ghi789
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id

# n8n Webhook Secret for Authentication
# CRITICAL: This secret validates requests to prevent unauthorized access
# Generate with: openssl rand -hex 32
# MUST match the secret configured in your n8n workflow
# NEVER commit this value - keep it secure in .env.local
N8N_WEBHOOK_SECRET=your-secure-random-secret-min-32-characters-use-openssl-rand-hex-32

# Rate Limiting (Optional - defaults shown)
RATE_LIMIT_WINDOW=60000           # Time window in milliseconds (default: 1 minute)
RATE_LIMIT_MAX_REQUESTS=5         # Max requests per window per IP (default: 5)

# ==============================================================================
# DATABASE (Optional - for future use)
# ==============================================================================
# DATABASE_URL=
# API_SECRET_KEY=

# ==============================================================================
# SECURITY WARNINGS
# ==============================================================================
# ⚠️ CRITICAL: Never commit .env.local or .env to Git
# ⚠️ Use strong, unique values for all secrets (min 32 characters)
# ⚠️ Rotate secrets regularly (at least every 90 days)
# ⚠️ Use different values for development/staging/production
# ⚠️ Never expose API keys or secrets with NEXT_PUBLIC_ prefix
# ⚠️ Review all environment variables before deployment
